pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

--#region 1. MAIN

--palette
pal_global={
    {2,  128}, --Bergundy  to  Dark-Brown
    {15, 134}, --Beige     to  Dark-Beige
    {4,  133} --Brown     to  Choc-Brown
}

function _init()
    t=0
end


function _update60()
    t+=1
end


function _draw()
	cls(5)
    apply_global_pal()
    cprint("NOIR", 63, 20, 6)

    spr(0,54,54,2,3)

    --debug
    print(t, 1, 1, 6)
end


--#region 2. CLOCK




--#region 3. PLAYER




--#region 4. ENTITIES




--#region 5. COMBAT




--#region 6. VFX




--#region 7. UTILITIES

function cprint(txt,x,y,clr) --centered print
    print(txt,x-#txt*2,y,clr)
end

function apply_global_pal()
    palt(0,false)
    palt(1,true)
	for clr in all(pal_global) do
		pal(clr[1], clr[2], 1)
	end
end



































