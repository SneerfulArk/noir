pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

--#region 1. MAIN

    --palette
    pal_global={
        {2,  128}, --Bergundy  to  Dark-Brown
        {15, 134}, --Beige     to  Dark-Beige
        {4,  133}, --Brown     to  Choc-Brown
    }

    function _init()
        init_clock()
        init_player()
        init_combat()
        init_enemies()
        init_testing()
    end


    function _update60()
        update_clock()
        update_player()
        update_combat()
        update_enemies()
        update_testing()
    end


    function _draw()

        
        cls(5)
        doshake()
        apply_global_pal()

        draw_player()
        draw_enemies()
        draw_testing()

        --debug
        print(ticks, 1, 1, 6)
        cprint("NOIR", 63, 20, 6)
        
        --[[line(63,0,63,127,12) --vertical debug line
        line(64,0,64,127)

        line(0,63,127,63) --horizontal debug line
        line(0,64,127,64)--]]
    end


--#region 2. CLOCK

    function init_clock()
        ticks = 0
    end

    function update_clock()
        ticks += 1
    end


--#region 3. PLAYER

    function init_player()
        plr={
            x   = 57,
            y   = 64,
            w   = 2,
            h   = 3,
            spr = 0,
            spd = 0,
            facing = 1,
            fx  = false,
        }
    end

    function update_player()

        if plr.facing == 1 then
            plr.fx = true
        elseif plr.facing == 0 then
            plr.fx = false
        end

        if en.x > plr.x then
            plr.facing = 1
        elseif en.x < plr.x then
            plr.facing = 0
        end

    end

    function draw_player()
        draw_obj(plr)
    end


--#region 4. ENEMIES

    function init_enemies()
        en={
            x   = 74,
            y   = 64,
            w   = 2,
            h   = 3,
            spr = 2,
            spd = 1,
            fx  = true
        }
    end

    function update_enemies()
        move_obj(en)
        if (en.x+16) >= 115 then
            en.spd    = -1
            en.fx     = false
        end
        if en.x<=15 then
            en.spd    = 1
            en.fx     = true
        end
    end

    function draw_enemies()
        draw_obj(en)
    end


--#region 5. COMBAT

    function init_combat()

        hitstop=0
        shake=0

    end

    function update_combat()

        hitstop -= 1
        if shake>=1 then shake-=1 end

        if en.x <= (plr.x+20) and en.x >= (plr.x-10) then
            if btn(4) and hitstop<=0 then
                hitstop = 15
                shake = 3
                sfx(0)
            end
        end

    end


--#region 6. VFX




--#region 7. UTILITIES

    function cprint(txt,x,y,clr) --centered print
        print(txt,x-#txt*2,y,clr)
    end

    function apply_global_pal()
        palt(0,false)
        palt(1,true)
        for clr in all(pal_global) do
            pal(clr[1], clr[2], 1)
        end
    end

    function move_obj(obj)
        obj.x+=obj.spd
    end

    function draw_obj(obj)
        spr(obj.spr,obj.x,obj.y,obj.w,obj.h,obj.fx)
    end

    function doshake()

        local shakex=rnd(shake)-(shake/2)
        local shakey=rnd(shake)-(shake/2)
        
        camera(shakex,shakey)
        
        if shake>10 then
            shake *= 0.9
        else
            shake -= 1
            if shake<1 then
                shake = 0
            end
        end

    end


--#region 8. TESTING

    function init_testing()

    end

    function update_testing()

    end

    function draw_testing()

    end


      




















