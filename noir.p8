pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

-----#region 1. MAIN

--palette
pal_global={
    {2,  128}, --Bergundy  to  Dark-Brown
    {15, 134}, --Beige     to  Dark-Beige
    {4,  133}, --Brown     to  Choc-Brown
}

function _init()
    init_clock()
    init_player()
    init_enemies()
end


function _update60()
    update_clock()
    update_player()
    update_enemies()
end


function _draw()
	cls(5)
    apply_global_pal()

    draw_player()
    draw_enemies()

    --debug
    print(ticks, 1, 1, 6)
    cprint("NOIR", 63, 20, 6)
end


-----#region 2. CLOCK

function init_clock()
    ticks = 0
end

function update_clock()
    ticks += 1
end


-----#region 3. PLAYER

function init_player()
    plr={
        x   = 56,
        y   = 64,
        w   = 2,
        h   = 3,
        spr = 0,
        spd = 0,
        fx  = true
    }
end

function update_player()
    move_obj(plr)
    if btn(0) then
        plr.spd = -1
    elseif btn(1) then
        plr.spd = 1
    else
        plr.spd = 0
    end
    if plr.spd>0 then
        plr.fx=false
    elseif plr.spd<0 then
        plr.fx=true
    end
end

function draw_player()
    draw_obj(plr)
end


-----#region 4. ENEMIES

function init_enemies()
    en={
        x   = 24,
        y   = 64,
        w   = 2,
        h   = 3,
        spr = 2,
        spd = 1,
        fx  = false
    }
end

function update_enemies()
    move_obj(en)
    if (en.x+13) >= 128 then
        en.spd    = -1
        en.fx     = true
    end
    if en.x<=0 then
        en.spd    = 1
        en.fx     = false
    end
end

function draw_enemies()
    draw_obj(en)
end

-----#region 5. COMBAT




-----#region 6. VFX




-----#region 7. UTILITIES

function cprint(txt,x,y,clr) --centered print
    print(txt,x-#txt*2,y,clr)
end

function apply_global_pal()
    palt(0,false)
    palt(1,true)
	for clr in all(pal_global) do
		pal(clr[1], clr[2], 1)
	end
end

function move_obj(obj)
    obj.x+=obj.spd
end

function draw_obj(obj)
    spr(obj.spr,obj.x,obj.y,obj.w,obj.h,obj.fx)
end




























