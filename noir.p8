pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

-----#region 1. MAIN

--palette
pal_global={
    {2,  128}, --Bergundy  to  Dark-Brown
    {15, 134}, --Beige     to  Dark-Beige
    {4,  133}, --Brown     to  Choc-Brown
}

function _init()
    init_clock()
    init_player()
    init_enemies()
end


function _update60()
    update_clock()
    update_player()
    update_enemies()
end


function _draw()
	cls(5)
    apply_global_pal()

    draw_player()
    draw_enemies()

    --debug
    print(ticks, 1, 1, 6)
    cprint("NOIR", 63, 20, 6)
end


-----#region 2. CLOCK

function init_clock()
    ticks=0
end

function update_clock()
    ticks+=1
end


-----#region 3. PLAYER

function init_player()
    plr={
        x=48,
        y=64,
        w=2,
        h=3,
        spr=0
    }
end

function update_player()
    
end

function draw_player()
    spr(plr.spr,plr.x,plr.y,plr.w,plr.h)
end


-----#region 4. ENEMIES

function init_enemies()
    en={
        x=62,
        y=64,
        w=2,
        h=3,
        spr=2
    }
end

function update_enemies()

end

function draw_enemies()
    spr(en.spr,en.x,en.y,en.w,en.h)
end

-----#region 5. COMBAT




-----#region 6. VFX




-----#region 7. UTILITIES

function cprint(txt,x,y,clr) --centered print
    print(txt,x-#txt*2,y,clr)
end

function apply_global_pal()
    palt(0,false)
    palt(1,true)
	for clr in all(pal_global) do
		pal(clr[1], clr[2], 1)
	end
end
































